generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id         Int      @id @default(autoincrement())
  accessCode String   @unique
  balance    Float    @default(0)
  role       String   @default("USER")
  createdAt  DateTime @default(now())
}
